<Window x:Class="TaroVS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Taro Shop — MVP"
        Width="1200"
        Height="760"
        Background="#F6F7FB">

    <Window.Resources>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#EEF2FF"/>
            <Setter Property="Foreground" Value="#3730A3"/>
            <Setter Property="BorderBrush" Value="#C7D2FE"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="18,12"/>
            <Setter Property="Margin" Value="0,6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#374151"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E5E7EB"/>
            <Setter Property="RowHeight" Value="42"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="Background" Value="White"/>
        </Style>

    </Window.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                CornerRadius="22"
                Padding="26,18"
                Margin="0,0,0,22">

            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="ИС магазина карт Таро — MVP"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#1F2937"/>

                    <TextBlock Text="Учет товаров, клиентов, заказов, отчетов и истории изменений"
                               FontSize="14"
                               Foreground="#6B7280"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="Демо-данные"
                            Command="{Binding SeedDemoCommand}"/>

                    <Button Content="Сохранить"
                            Background="#ECFDF5"
                            Foreground="#047857"
                            BorderBrush="#A7F3D0"
                            Command="{Binding SaveDataCommand}"/>

                    <Button Content="Загрузить"
                            Command="{Binding LoadDataCommand}"/>
                </StackPanel>
            </DockPanel>

        </Border>

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="22"
                Padding="20">

            <TabControl TabStripPlacement="Left"
                        Background="Transparent"
                        BorderThickness="0">

                <TabItem Header="Dashboard">
                    <Grid Margin="24,10,10,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,20">
                            <TextBlock Text="Главная панель"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#111827"/>

                            <TextBlock Text="Сводная информация по работе магазина"
                                       Foreground="#6B7280"
                                       Margin="0,6,0,0"/>
                        </StackPanel>

                        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,24">

                            <Border Background="#FAFAFF" CornerRadius="16" Padding="20" Margin="0,0,12,0" BorderBrush="#E5E7EB" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Заказы всего" Foreground="#6B7280"/>
                                    <TextBlock Text="{Binding Orders.Count}" FontSize="34" FontWeight="Bold" Foreground="#111827"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#FAFAFF" CornerRadius="16" Padding="20" Margin="0,0,12,0" BorderBrush="#E5E7EB" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Товаров" Foreground="#6B7280"/>
                                    <TextBlock Text="{Binding Products.Count}" FontSize="34" FontWeight="Bold" Foreground="#111827"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#FAFAFF" CornerRadius="16" Padding="20" Margin="0,0,12,0" BorderBrush="#E5E7EB" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Клиентов" Foreground="#6B7280"/>
                                    <TextBlock Text="{Binding Customers.Count}" FontSize="34" FontWeight="Bold" Foreground="#111827"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#FAFAFF" CornerRadius="16" Padding="20" BorderBrush="#E5E7EB" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="История изменений" Foreground="#6B7280"/>
                                    <TextBlock Text="{Binding Changes.Count}" FontSize="34" FontWeight="Bold" Foreground="#111827"/>
                                </StackPanel>
                            </Border>

                        </UniformGrid>

                        <Border Grid.Row="2"
                                Background="White"
                                CornerRadius="18"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                Padding="18">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Последние заказы"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Margin="0,0,0,14"/>

                                <DataGrid Grid.Row="1"
                                          ItemsSource="{Binding Orders}"
                                          SelectedItem="{Binding SelectedOrder}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                                        <DataGridTextColumn Header="Клиент" Binding="{Binding Customer.FullName}" Width="180"/>
                                        <DataGridTextColumn Header="Товар" Binding="{Binding Product.Name}" Width="220"/>
                                        <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="150"/>
                                        <DataGridTextColumn Header="Сумма" Binding="{Binding Total}" Width="120"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>

                        </Border>

                        <UniformGrid Grid.Row="3" Columns="2" Margin="0,24,0,0">
                            <Border Background="#FAFAFF" CornerRadius="16" Padding="18" Margin="0,0,12,0" BorderBrush="#E5E7EB" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Быстрые действия" FontWeight="Bold"/>
                                    <TextBlock Text="Добавить товар · Создать заказ · Сформировать отчёт"
                                               Foreground="#6B7280"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#FAFAFF" CornerRadius="16" Padding="18" BorderBrush="#E5E7EB" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Состояние системы" FontWeight="Bold"/>
                                    <TextBlock Text="JSON-хранилище · Автосохранение включено · Версия 1.5"
                                               Foreground="#6B7280"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                    </Grid>
                </TabItem>

                <TabItem Header="Товары">
                    <Grid Margin="24,10,10,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Background="#FAFAFF" CornerRadius="16" Padding="14" Margin="0,0,0,16">
                            <WrapPanel>
                                <TextBox Width="200" Text="{Binding NewProductName}" />
                                <TextBox Width="120" Text="{Binding NewProductCategory}" />
                                <TextBox Width="120" Text="{Binding NewProductPublisher}" />
                                <TextBox Width="90" Text="{Binding NewProductPrice}" />
                                <TextBox Width="70" Text="{Binding NewProductStock}" />

                                <Button Content="Добавить товар" Command="{Binding AddProductCommand}"/>
                                <Button Content="Удалить" Command="{Binding DeleteProductCommand}"/>
                            </WrapPanel>
                        </Border>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding Products}"
                                  SelectedItem="{Binding SelectedProduct}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="220"/>
                                <DataGridTextColumn Header="Категория" Binding="{Binding Category}" Width="140"/>
                                <DataGridTextColumn Header="Издательство" Binding="{Binding Publisher}" Width="160"/>
                                <DataGridTextColumn Header="Цена" Binding="{Binding Price}" Width="100"/>
                                <DataGridTextColumn Header="Остаток" Binding="{Binding Stock}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <TabItem Header="Клиенты">
                    <Grid Margin="24,10,10,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Background="#FAFAFF" CornerRadius="16" Padding="14" Margin="0,0,0,16">
                            <WrapPanel>
                                <TextBox Width="200" Text="{Binding NewCustomerName}" />
                                <TextBox Width="150" Text="{Binding NewCustomerPhone}" />
                                <TextBox Width="220" Text="{Binding NewCustomerEmail}" />
                                <Button Content="Добавить клиента" Command="{Binding AddCustomerCommand}"/>
                            </WrapPanel>
                        </Border>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding Customers}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                                <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="240"/>
                                <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="160"/>
                                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="220"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <TabItem Header="Заказы">
                    <Grid Margin="24,10,10,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Background="#FAFAFF" CornerRadius="16" Padding="14" Margin="0,0,0,16">
                            <WrapPanel>
                                <ComboBox Width="220"
                                          ItemsSource="{Binding Customers}"
                                          SelectedItem="{Binding SelectedCustomer}"
                                          DisplayMemberPath="FullName"/>

                                <ComboBox Width="220"
                                          ItemsSource="{Binding Products}"
                                          SelectedItem="{Binding SelectedOrderProduct}"
                                          DisplayMemberPath="Name"/>

                                <TextBox Width="70" Text="{Binding NewOrderQuantity}"/>

                                <Button Content="Создать заказ" Command="{Binding AddOrderCommand}"/>
                                <Button Content="Отменить заказ" Command="{Binding CancelOrderCommand}"/>
                            </WrapPanel>
                        </Border>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding Orders}"
                                  SelectedItem="{Binding SelectedOrder}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                                <DataGridTextColumn Header="Клиент" Binding="{Binding Customer.FullName}" Width="180"/>
                                <DataGridTextColumn Header="Товар" Binding="{Binding Product.Name}" Width="220"/>
                                <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="80"/>
                                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="150"/>
                                <DataGridTextColumn Header="Сумма" Binding="{Binding Total}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <TabItem Header="Отчёты">
                    <StackPanel Margin="24">
                        <Button Content="Сформировать отчёт"
                                Width="190"
                                Command="{Binding BuildReportCommand}"/>

                        <Border Background="#FAFAFF" CornerRadius="16" Padding="18" Margin="0,16,0,0">
                            <TextBox Text="{Binding ReportText}"
                                     Height="300"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     TextWrapping="Wrap"
                                     IsReadOnly="True"/>
                        </Border>
                    </StackPanel>
                </TabItem>

                <TabItem Header="История изменений">
                    <Grid Margin="24,10,10,10">
                        <DataGrid ItemsSource="{Binding ChangeLog}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Дата" Binding="{Binding Date}" Width="160"/>
                                <DataGridTextColumn Header="Объект" Binding="{Binding ObjectType}" Width="140"/>
                                <DataGridTextColumn Header="Действие" Binding="{Binding Action}" Width="260"/>
                                <DataGridTextColumn Header="Пользователь" Binding="{Binding UserName}" Width="150"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

            </TabControl>

        </Border>

    </Grid>
</Window>