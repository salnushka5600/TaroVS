<Window x:Class="TaroVS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Taro Shop"
        Width="1200"
        Height="760"
        Background="#F5F3FF">

    <Window.Resources>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#7C3AED"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="9"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="BorderBrush" Value="#DDD6FE"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="7"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="BorderBrush" Value="#DDD6FE"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#EDE9FE"/>
            <Setter Property="RowHeight" Value="42"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
        </Style>

    </Window.Resources>

    <Grid Margin="26">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                CornerRadius="24"
                Padding="24"
                Margin="0,0,0,22">

            <DockPanel>

                <StackPanel>
                    <TextBlock Text="Taro Shop"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#2E1065"/>

                    <TextBlock Text="Информационная система магазина карт Таро"
                               Foreground="#6B7280"
                               FontSize="14"
                               Margin="0,6,0,0"/>
                </StackPanel>

            </DockPanel>

        </Border>

        <Grid Grid.Row="1"
              x:Name="AdminPanel">

            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>

                    <Style.Triggers>

                        <DataTrigger Binding="{Binding IsAdmin}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>

                    </Style.Triggers>

                </Style>
            </Grid.Style>

            <Border Background="White" CornerRadius="24" Padding="20">
                <TabControl TabStripPlacement="Left" Background="Transparent" BorderThickness="0">
                    <TabItem Header="Dashboard">
                        <Grid Margin="24,10,10,10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Margin="0,0,0,20">
                                <TextBlock Text="Админ-панель"
                                           FontSize="26"
                                           FontWeight="Bold"
                                           Foreground="#111827"/>

                                <TextBlock Text="Контроль товаров, заказов и общей информации по магазину"
                                           Foreground="#6B7280"
                                           Margin="0,6,0,0"/>

                            </StackPanel>

                            <UniformGrid Grid.Row="1"
                                         Columns="3"
                                         Margin="0,0,0,22">

                                <Border Background="#FAFAFF"
                                        CornerRadius="18"
                                        Padding="22"
                                        Margin="0,0,14,0"
                                        BorderBrush="#EDE9FE"
                                        BorderThickness="1">

                                    <StackPanel>

                                        <TextBlock Text="Товаров"
                                                   Foreground="#6B7280"/>

                                        <TextBlock Text="{Binding Products.Count}"
                                                   FontSize="36"
                                                   FontWeight="Bold"
                                                   Foreground="#2E1065"/>

                                    </StackPanel>

                                </Border>

                                <Border Background="#FAFAFF"
                                        CornerRadius="18"
                                        Padding="22"
                                        Margin="0,0,14,0"
                                        BorderBrush="#EDE9FE"
                                        BorderThickness="1">

                                    <StackPanel>

                                        <TextBlock Text="Клиентов"
                                                   Foreground="#6B7280"/>

                                        <TextBlock Text="{Binding Customers.Count}"
                                                   FontSize="36"
                                                   FontWeight="Bold"
                                                   Foreground="#2E1065"/>

                                    </StackPanel>

                                </Border>

                                <Border Background="#FAFAFF"
                                        CornerRadius="18"
                                        Padding="22"
                                        BorderBrush="#EDE9FE"
                                        BorderThickness="1">

                                    <StackPanel>

                                        <TextBlock Text="Заказов"
                                                   Foreground="#6B7280"/>

                                        <TextBlock Text="{Binding Orders.Count}"
                                                   FontSize="36"
                                                   FontWeight="Bold"
                                                   Foreground="#2E1065"/>

                                    </StackPanel>

                                </Border>

                            </UniformGrid>

                            <Border Grid.Row="2"
                                    Background="White"
                                    CornerRadius="18"
                                    BorderBrush="#EDE9FE"
                                    BorderThickness="1"
                                    Padding="18">

                                <Grid>

                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="Последние заказы"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Margin="0,0,0,14"/>

                                    <DataGrid Grid.Row="1"
                                              ItemsSource="{Binding Orders}"
                                              SelectedItem="{Binding SelectedOrder}">

                                        <DataGrid.Columns>

                                            <DataGridTextColumn Header="ID"
                                                                Binding="{Binding Id}"
                                                                Width="60"/>

                                            <DataGridTextColumn Header="Клиент"
                                                                Binding="{Binding Customer.FullName}"
                                                                Width="200"/>

                                            <DataGridTextColumn Header="Товар"
                                                                Binding="{Binding Product.Name}"
                                                                Width="220"/>

                                            <DataGridTextColumn Header="Кол-во"
                                                                Binding="{Binding Quantity}"
                                                                Width="80"/>

                                            <DataGridTextColumn Header="Статус"
                                                                Binding="{Binding Status}"
                                                                Width="140"/>

                                            <DataGridTextColumn Header="Сумма"
                                                                Binding="{Binding Total}"
                                                                Width="120"/>

                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>
    </Grid>
</Window>