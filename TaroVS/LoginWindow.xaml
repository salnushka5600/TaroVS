<Window x:Class="TaroVS.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация"
        Width="420"
        Height="430"
        WindowStartupLocation="CenterScreen"
        Background="#F5F3FF"
        ResizeMode="NoResize">

    <Grid Margin="24">

        <Border Background="White"
                CornerRadius="24"
                Padding="24">

            <StackPanel>

                <TextBlock Text="Taro Shop"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#7C3AED"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Вход в систему"
                           FontSize="14"
                           Foreground="#6B7280"
                           HorizontalAlignment="Center"
                           Margin="0,6,0,20"/>

                <TextBlock Text="Логин"/>

                <TextBox x:Name="LoginBox"
                         Height="38"
                         Margin="0,6,0,12"/>

                <TextBlock Text="Пароль"/>

                <PasswordBox x:Name="PasswordBox"
                             Height="38"
                             Margin="0,6,0,18"/>

                <Button Content="Войти"
                        Height="44"
                        Width="200"
                        Background="#7C3AED"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        Click="LoginButton_Click"/>

                <TextBlock Text="admin/admin — администратор; client/client — клиент"
                           TextWrapping="Wrap"
                           Foreground="#6B7280"
                           FontSize="12"
                           Margin="0,16,0,0"
                           TextAlignment="Center"/>

            </StackPanel>

        </Border>

    </Grid>
</Window>